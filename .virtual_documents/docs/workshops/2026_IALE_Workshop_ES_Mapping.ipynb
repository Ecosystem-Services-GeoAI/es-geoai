def add_shp(metadata, shp_path):
    shp_layer = gpd.read_file(shp_path)  # Replace with your shapefile path

    # Ensure the states shapefile is in EPSG:3857
    shp_layer = shp_layer.to_crs("EPSG:4326")

    # Convert the locations DataFrame to a GeoDataFrame with the initial WGS84 CRS (EPSG:4326)
    geometry = [Point(xy) for xy in zip(metadata['longitude'], metadata['latitude'])]
    metadata_gdf = gpd.GeoDataFrame(metadata, geometry=geometry, crs="EPSG:4326")  # WGS84 CRS

    # Reproject the locations to EPSG:3857 to match the states shapefile
    metadata_gdf = metadata_gdf.to_crs(shp_layer.crs)

    # Perform a spatial join to assign each location to the corresponding state
    metadata_joint = gpd.sjoin(metadata_gdf, shp_layer, how='left', predicate='within', lsuffix='left', rsuffix='right')
    ##NAME20 column is urban.

    #Print the result
    #print(metadata_layer.head())

    metadata_joint.drop(columns=['index_right'], inplace=True)
    metadata_joint.columns

    return metadata_joint


